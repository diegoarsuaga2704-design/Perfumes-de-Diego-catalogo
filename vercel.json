{
  "functions": {
    "api/og.mjs": {
      "includeFiles": "dist/index.html"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "perfumes-de-diego-catalogo.vercel.app" }
      ],
      "destination": "https://perfumesdediego.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/product/:nombre/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawl|spider|facebookexternalhit|whatsapp|embed|slack|discord|telegram|pinterest|preview|linkedin|skype|vkshare).*"
        }
      ],
      "destination": "/api/og?type=product&id=:id&nombre=:nombre"
    },
    {
      "source": "/casa/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawl|spider|facebookexternalhit|whatsapp|embed|slack|discord|telegram|pinterest|preview|linkedin|skype|vkshare).*"
        }
      ],
      "destination": "/api/og?type=casa&slug=:slug"
    },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ]
}
